{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build & Run",
            "type": "shell",
            "windows": {
                "command": "cmake -S . -B build && cmake --build build --config ${input:buildConfig} --target run",
                "options": {
                    "shell": {
                        "executable": "cmd.exe",
                        "args": [
                            "/d",
                            "/c"
                        ]
                    }
                }
            },
            "linux": {
                "command": "cmake -S . -B build -DCMAKE_BUILD_TYPE=${input:buildConfig} && cmake --build build --target run",
                "options": {
                    "cwd": "${workspaceFolder}"
                }
            },
            "group": {
                "kind": "build"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build",
            "type": "shell",
            "windows": {
                "command": "cmake -S . -B build && cmake --build build --config ${input:buildConfig}",
                "options": {
                    "shell": {
                        "executable": "cmd.exe",
                        "args": [
                            "/d",
                            "/c"
                        ]
                    }
                }
            },
            "linux": {
                "command": "cmake -S . -B build -DCMAKE_BUILD_TYPE=${input:buildConfig} && cmake --build build",
                "options": {
                    "cwd": "${workspaceFolder}"
                }
            },
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build Web",
            "type": "shell",
            "windows": {
                "command": "emcmake cmake -S . -B build-web -DCMAKE_BUILD_TYPE=${input:buildConfig} && cmake --build build-web",
                "options": {
                    "shell": {
                        "executable": "cmd.exe",
                        "args": [
                            "/d",
                            "/c"
                        ]
                    }
                }
            },
            "linux": {
                "command": "emcmake cmake -S . -B build-web -DCMAKE_BUILD_TYPE=${input:buildConfig} && cmake --build build-web",
                "options": {
                    "cwd": "${workspaceFolder}"
                }
            },
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Serve Web",
            "type": "shell",
            "command": "python3 -m http.server 8080",
            "options": {
                "cwd": "${workspaceFolder}/build-web"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Build & Run Web",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Web",
                "Serve Web"
            ],
            "group": "build",
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "buildConfig",
            "type": "pickString",
            "description": "Build configuration",
            "options": [
                "Debug",
                "Release",
                "Arcademia",
                "Arcademia_Debug"
            ],
            "default": "Debug"
        }
    ]
}