{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build & Run",
            "type": "shell",
            "windows": {
                "command": "cmake -S . -B build && cmake --build build --config ${input:buildConfig} --target run",
                "options": {
                    "shell": {
                        "executable": "cmd.exe",
                        "args": ["/d", "/c"]
                    }
                }
            },
            "linux": {
                "command": "cmake -DCMAKE_BUILD_TYPE=${input:buildConfig} .. && make run",
                "options": {
                    "cwd": "build"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build",
            "type": "shell",
            "windows": {
                "command": "cmake -S . -B build && cmake --build build --config ${input:buildConfig} --target run",
                "options": {
                    "shell": {
                        "executable": "cmd.exe",
                        "args": ["/d", "/c"]
                    }
                }
            },
            "linux": {
                "command": "cmake -DCMAKE_BUILD_TYPE=${input:buildConfig} .. && make",
                "options": {
                    "cwd": "build"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        }
    ],
    "inputs": [
        {
            "id": "buildConfig",
            "type": "pickString",
            "description": "Build configuration",
            "options": [
                "Debug",
                "Release",
                "Arcademia",
                "Arcademia_Debug",
            ],
            "default": "Debug"
        }
    ]
}